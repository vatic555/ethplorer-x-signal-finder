# Copy this file to .env for local development only.
# Never commit .env or any real credential values.
# DATABASE_URL is the standard PostgreSQL connection string used by database commands.
# Database commands redact credentials and must never print full connection strings.
DATABASE_URL=

# Placeholder names only. Never commit real credentials or copy secret values here.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REFRESH_TOKEN=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
